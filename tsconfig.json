{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,

    "rootDir": "./src",
    "outDir": "dist",
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts"]
}